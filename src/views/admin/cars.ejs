<!doctype html>
<html class="dark" lang="sk">
<head>
  <%- include('../components/head', { title: 'Admin Cars | Karzone' }) %>
</head>
<body class="bg-surface text-on-surface">
<%- include('../components/header') %>
<% const adminCars = typeof cars !== 'undefined' ? cars : []; %>

<main class="pt-32 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
  <section class="mb-14">
    <p class="text-primary text-xs tracking-[0.3em] uppercase mb-4">Admin Console</p>
    <h1 class="font-headline text-5xl md:text-7xl font-black tracking-tighter leading-[0.95]">Archive Registry.</h1>
  </section>

  <section class="bg-surface-container-low rounded-lg p-6 md:p-8 editorial-shadow overflow-x-auto">
    <table class="admin-table-luxe">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Brand / Model</th>
          <th>Price</th>
          <th>Year</th>
        </tr>
      </thead>
      <tbody>
        <% if (adminCars.length === 0) { %>
          <tr><td colspan="5">No vehicles in archive.</td></tr>
        <% } %>
        <% adminCars.forEach((car) => { %>
          <tr>
            <td><%= car.car_id %></td>
            <td><%= car.title %></td>
            <td><%= car.brand %> <%= car.model %></td>
            <td><%= car.price %> €</td>
            <td><%= car.year %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>

<%- include('../components/footer') %>
<script src="/assets/js/app.js"></script>
</body>
</html>
