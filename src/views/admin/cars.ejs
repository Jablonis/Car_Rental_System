<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin - Autá</title>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Epilogue:wght@300;400;500;600;700&display=swap" />
</head>
<body>
<%- include("../components/header") %>
<% const adminCars = typeof cars !== 'undefined' ? cars : []; %>

<main>
  <div class="page-header">
    <div class="container">
      <h1>Správa áut</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="card" style="padding: 0; overflow: hidden;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Názov</th>
              <th>Značka / model</th>
              <th>Cena</th>
              <th>Rok</th>
            </tr>
          </thead>
          <tbody>
            <% if (adminCars.length === 0) { %>
              <tr>
                <td colspan="5">Zatiaľ sa nenašli žiadne autá.</td>
              </tr>
            <% } %>
            <% adminCars.forEach((car) => { %>
              <tr>
                <td><%= car.car_id %></td>
                <td><%= car.title %></td>
                <td><%= car.brand %> <%= car.model %></td>
                <td><%= car.price %> €</td>
                <td><%= car.year %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include("../components/footer") %>
<script src="/assets/js/app.js"></script>
</body>
</html>
