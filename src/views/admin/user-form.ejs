<!doctype html>
<html class="dark" lang="sk">
<head>
  <%- include('../components/head', { title: (mode === 'create' ? 'Create Member' : 'Edit Member') + ' | Karzone' }) %>
</head>
<body class="bg-surface text-on-surface">
<%- include('../components/header') %>

<main class="pt-32 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-5">
      <p class="text-primary text-xs tracking-[0.3em] uppercase mb-4">Admin Console</p>
      <h1 class="font-headline text-5xl md:text-7xl font-black tracking-tighter leading-[0.95] mb-8"><%= mode === 'create' ? 'Create member.' : 'Refine member.' %></h1>
      <p class="text-on-surface-variant text-lg leading-relaxed">Shape permissions and identity in the same restrained language as the rest of the archive.</p>
    </div>

    <div class="lg:col-span-7 bg-surface-container-low rounded-lg p-6 md:p-10 editorial-shadow">
      <% if (errors && errors.length > 0) { %>
        <div class="alert-luxe form-error-list mb-8">
          <% errors.forEach((error) => { %><div><%= error.message %></div><% }) %>
        </div>
      <% } %>

      <form method="POST" action="<%= mode === 'create' ? '/admin/users/new' : '/admin/users/' + user.user_id + '/edit' %>" class="space-y-8">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Name</label>
          <input id="name" type="text" name="name" value="<%= formData.name || '' %>" class="form-input-luxe" />
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Email</label>
          <input id="email" type="email" name="email" value="<%= formData.email || '' %>" class="form-input-luxe" />
        </div>
        <% if (mode === 'create') { %>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Password</label>
            <input id="password" type="password" name="password" class="form-input-luxe" />
          </div>
        <% } %>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Role</label>
          <select id="isAdmin" name="isAdmin" class="form-select-luxe">
            <option value="0" <%= String(formData.isAdmin) === '0' ? 'selected' : '' %>>Member</option>
            <option value="1" <%= String(formData.isAdmin) === '1' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        <div class="flex flex-wrap gap-4 pt-4">
          <button type="submit" class="px-8 py-4 rounded-full bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-bold text-[10px] uppercase tracking-[0.24em]"><%= mode === 'create' ? 'Create member' : 'Save refinement' %></button>
          <a href="/admin/users" class="px-8 py-4 rounded-full border border-outline-variant/20 text-[10px] uppercase tracking-[0.24em] text-on-surface">Return to registry</a>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include('../components/footer') %>
<script src="/assets/js/app.js"></script>
</body>
</html>
