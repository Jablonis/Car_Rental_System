<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin - Používatelia</title>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Epilogue:wght@300;400;500;600;700&display=swap" />
</head>
<body>
<%- include("../components/header") %>

<main>
  <div class="page-header">
    <div class="container">
      <h1>Správa používateľov</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <% if (deleteError) { %>
        <div class="alert alert-error"><%= deleteError %></div>
      <% } %>

      <form method="GET" action="/admin/users" class="search-bar">
        <input
          type="text"
          name="search"
          class="form-input"
          placeholder="Hľadať podľa mena alebo emailu"
          value="<%= search || '' %>"
        />
        <button class="btn btn-small btn-primary" type="submit">Hľadať</button>
        <a class="btn btn-small" href="/admin/users/new">Vytvoriť používateľa</a>
      </form>

      <div class="card" style="padding: 0; overflow: hidden; margin-top: 24px;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Meno</th>
              <th>Email</th>
              <th>Admin</th>
              <th>Akcie</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr>
                <td colspan="5">Nenašli sa žiadni používatelia.</td>
              </tr>
            <% } %>

            <% users.forEach((user) => { %>
              <tr>
                <td><%= user.user_id %></td>
                <td><%= user.name %></td>
                <td><%= user.email %></td>
                <td><%= user.isAdmin ? "Áno" : "Nie" %></td>
                <td>
                  <div class="car-actions">
                    <a href="/admin/users/<%= user.user_id %>/edit" class="btn btn-small">Upraviť</a>
                    <form method="POST" action="/admin/users/<%= user.user_id %>/delete" style="display:inline;">
                      <button type="submit" class="btn btn-small btn-danger">Vymazať</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include("../components/footer") %>
<script src="/assets/js/app.js"></script>
</body>
</html>
