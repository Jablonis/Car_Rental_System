<!doctype html>
<html class="dark" lang="sk">
<head>
  <%- include('../components/head', { title: (mode === 'create' ? 'Acquire New Piece' : 'Refine Archive Entry') + ' | Karzone' }) %>
</head>
<body class="bg-surface text-on-surface" data-page="cars">
<%- include('../components/header') %>

<main class="pt-32 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-5">
      <p class="text-primary text-xs tracking-[0.3em] uppercase mb-4">Archive Intake</p>
      <h1 class="font-headline text-5xl md:text-7xl font-black tracking-tighter leading-[0.95] mb-8">
        <%= mode === 'create' ? 'Introduce a new machine.' : 'Refine the composition.' %>
      </h1>
      <p class="text-on-surface-variant text-lg leading-relaxed max-w-xl">
        Build the story with restraint—headline, provenance, technical notes, and the visual signature of the piece.
      </p>
    </div>
    <div class="lg:col-span-7 bg-surface-container-low rounded-lg p-6 md:p-10 editorial-shadow">
      <% if (errors && errors.length > 0) { %>
        <div class="alert-luxe form-error-list mb-8">
          <% errors.forEach((error) => { %>
            <div><%= error.message %></div>
          <% }) %>
        </div>
      <% } %>

      <form method="POST" action="<%= mode === 'create' ? '/cars/new' : '/cars/' + car.car_id + '/edit' %>" class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Title</label>
            <input class="form-input-luxe" id="title" type="text" name="title" value="<%= formData.title || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Brand</label>
            <input class="form-input-luxe" id="brand" type="text" name="brand" value="<%= formData.brand || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Model</label>
            <input class="form-input-luxe" id="model" type="text" name="model" value="<%= formData.model || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Year</label>
            <input class="form-input-luxe" id="year" type="number" name="year" value="<%= formData.year || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Price</label>
            <input class="form-input-luxe" id="price" type="number" name="price" value="<%= formData.price || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Mileage</label>
            <input class="form-input-luxe" id="mileage" type="number" name="mileage" value="<%= formData.mileage || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Fuel</label>
            <input class="form-input-luxe" id="fuel" type="text" name="fuel" value="<%= formData.fuel || '' %>" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Transmission</label>
            <input class="form-input-luxe" id="transmission" type="text" name="transmission" value="<%= formData.transmission || '' %>" />
          </div>
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Image URL</label>
          <input class="form-input-luxe" id="image" type="text" name="image" value="<%= formData.image || '' %>" />
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Editorial Notes</label>
          <textarea class="form-textarea-luxe" id="description" name="description"><%= formData.description || '' %></textarea>
        </div>
        <div class="flex flex-wrap gap-4 pt-4">
          <button class="px-8 py-4 rounded-full bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-bold text-[10px] uppercase tracking-[0.24em] hover:scale-[1.02] transition-transform" type="submit"><%= mode === 'create' ? 'Add to Archive' : 'Save Refinement' %></button>
          <a class="px-8 py-4 rounded-full border border-outline-variant/20 text-[10px] uppercase tracking-[0.24em] text-on-surface" href="/my-cars">Return to Garage</a>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include('../components/footer') %>
<button id="backToTop" type="button" aria-label="Back to top">↑</button>
<script src="/assets/js/app.js"></script>
</body>
</html>
