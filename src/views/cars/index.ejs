<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Ponuka áut</title>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Epilogue:wght@300;400;500;600;700&display=swap" />
</head>
<body data-page="cars">
<%- include("../components/header") %>

<main>
  <div class="page-header">
    <div class="container">
      <h1>Ponuka áut</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <form method="GET" action="/cars" class="search-bar" id="filterForm">
        <input
          type="text"
          id="carSearch"
          name="search"
          class="form-input"
          placeholder="Hľadať podľa názvu, značky alebo modelu"
          value="<%= search || '' %>"
        />
        <input
          type="number"
          id="minPrice"
          name="minPrice"
          class="form-input"
          placeholder="Cena od"
          value="<%= minPrice || '' %>"
          min="0"
          step="100"
        />
        <input
          type="number"
          id="maxPrice"
          name="maxPrice"
          class="form-input"
          placeholder="Cena do"
          value="<%= maxPrice || '' %>"
          min="0"
          step="100"
        />
        <select id="sort" name="sort" class="form-select">
          <option value="">Najnovšie</option>
          <option value="price_asc" <%= sort === "price_asc" ? "selected" : "" %>>Cena od najnižšej</option>
          <option value="price_desc" <%= sort === "price_desc" ? "selected" : "" %>>Cena od najvyššej</option>
          <option value="year_desc" <%= sort === "year_desc" ? "selected" : "" %>>Najnovší rok</option>
          <option value="year_asc" <%= sort === "year_asc" ? "selected" : "" %>>Najstarší rok</option>
        </select>
        <button type="submit" class="btn btn-small btn-primary">Filtrovať</button>
        <a href="/cars" class="btn btn-small">Reset</a>
      </form>

      <div id="carList" class="grid-3">
        <% cars.forEach((car) => { %>
          <article class="car-card" data-name="<%= car.title %> <%= car.brand %> <%= car.model %>">
            <img class="car-card-img" src="<%= car.image %>" alt="<%= car.title %>" />
            <div class="car-card-body">
              <h3 class="car-card-title"><%= car.title %></h3>
              <div class="car-meta">
                <span class="car-meta-item"><%= car.brand %> <%= car.model %></span>
                <span class="car-meta-item"><%= car.year %></span>
                <span class="car-meta-item"><%= car.mileage %> km</span>
                <span class="car-meta-item"><%= car.fuel %></span>
                <span class="car-meta-item"><%= car.transmission %></span>
              </div>
              <div class="car-price"><%= car.price %> €</div>
              <div class="car-actions">
                <a class="btn btn-small btn-primary" href="/cars/<%= car.car_id %>">Detail</a>
                <button type="button" class="btn btn-small car-toggle">Zobraziť detaily</button>
              </div>
              <div class="car-details">
                <p><strong>Popis:</strong> <%= car.description %></p>
              </div>
            </div>
          </article>
        <% }) %>
      </div>

      <% if (cars.length === 0) { %>
        <p id="noResults">Nenašli sa žiadne autá.</p>
      <% } else { %>
        <p id="noResults" hidden>Nenašli sa žiadne autá podľa zadaného filtra.</p>
      <% } %>
    </div>
  </section>
</main>

<%- include("../components/footer") %>
<script src="/assets/js/app.js"></script>
</body>
</html>
