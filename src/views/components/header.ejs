<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-brand">
      <span class="site-brand__mark">K</span>
      <span class="site-brand__text">KARZONE</span>
    </a>

    <nav class="main-nav">
      <a href="/" data-page="home" class="nav-link">Home</a>
      <a href="/cars" data-page="cars" class="nav-link">Vehicles</a>
      <a href="/about" data-page="about" class="nav-link">About</a>
      <a href="/journal" data-page="journal" class="nav-link">Journal</a>
      <a href="/contact" data-page="contact" class="nav-link">Contact</a>

      <% if (locals.isAuthenticated) { %>
        <a href="/my-cars" class="nav-link">My Garage</a>
        <% if (locals.isAdmin) { %>
          <a href="/admin/users" class="nav-link">Users</a>
          <a href="/admin/cars" class="nav-link">Cars</a>
          <a href="/admin/blogs" class="nav-link">Blogs</a>
        <% } %>
      <% } %>
    </nav>

    <div class="site-header__actions">
      <% if (locals.isAuthenticated) { %>
        <span class="site-header__user"><%= locals.user.name %></span>
        <a href="/cars/new" class="site-header__cta site-header__cta--ghost">Add listing</a>
        <form method="POST" action="/logout" class="site-header__logout-form">
          <button type="submit" class="site-header__cta">Log out</button>
        </form>
      <% } else { %>
        <a href="/login" class="nav-link nav-link--compact">Login</a>
        <a href="/signup" class="site-header__cta">Contact us</a>
      <% } %>
    </div>

    <button class="nav-toggle" type="button" aria-label="Open menu">
      <span></span>
      <span></span>
    </button>
  </div>
</header>
