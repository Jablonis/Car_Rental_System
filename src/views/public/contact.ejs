<!doctype html>
<html class="dark" lang="sk">
<head>
  <%- include('../components/head', { title: 'Velocity | Contact us' }) %>
</head>
<body class="bg-surface text-on-surface" data-page="contact" id="top">
<%- include('../components/header') %>

<main class="kz-subpage kz-subpage--contact kz-shell">
  <section class="kz-contact-hero">
    <div class="kz-contact-hero__copy js-reveal" data-reveal>
      <span class="kz-page-hero__eyebrow">Contact us</span>
      <h1>Connect with<br>Velocity.</h1>
      <p>Inquiry is the first gear of an extraordinary journey. Whether you are seeking a rare acquisition, a short-term arrival, or a private event handoff, our curators are ready to respond.</p>

      <div class="kz-contact-cards">
        <article>
          <span>Studio location</span>
          <strong>Námestovo, Slovakia</strong>
          <p>Appointments by arrangement only.</p>
        </article>
        <article>
          <span>Direct line</span>
          <strong>+421 900 000 000</strong>
          <p>Private concierge & vehicle requests.</p>
        </article>
        <article>
          <span>Email</span>
          <strong>hello@velocity.com</strong>
          <p>Editorial, business and collection inquiries.</p>
        </article>
      </div>
    </div>

    <div class="kz-contact-hero__visual js-reveal" data-reveal>
      <img src="/assets/img/hero-garage.jpg" alt="Velocity garage detail" data-parallax="0.02" />
      <div class="kz-contact-hero__note">
        <span>Private collection</span>
        <strong>Concierge response within 24h</strong>
      </div>
    </div>
  </section>

  <section class="kz-contact-grid">
    <div class="kz-contact-panel js-reveal" data-reveal>
      <h3>Direct inquiry</h3>

      <% if (success) { %>
        <div class="alert-luxe mb-6">Your inquiry has been sent. We will get back to you shortly.</div>
      <% } %>

      <% if (errors && errors.length) { %>
        <div class="alert-luxe form-error-list mb-6">
          <% errors.forEach((error) => { %>
            <div><%= error.message %></div>
          <% }) %>
        </div>
      <% } %>

      <form id="contactForm" class="kz-contact-form" method="POST" action="/contact">
        <div class="kz-form-row">
          <input id="contact-name" class="input-bottom" placeholder="Name" type="text" name="name" value="<%= formData?.name || '' %>" required />
          <input id="contact-email" class="input-bottom" placeholder="Email Address" type="email" name="email" value="<%= formData?.email || '' %>" required />
        </div>
        <div class="kz-form-row kz-form-row--single">
          <select id="contact-car" class="input-bottom" name="car">
            <option value="">Select a focus</option>
            <% cars.forEach((car) => { %>
              <option value="<%= car.title %>" <%= formData?.car === car.title ? 'selected' : '' %>><%= car.brand %> <%= car.model %> — <%= car.title %></option>
            <% }) %>
            <option value="Other" <%= formData?.car === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div class="kz-form-row kz-form-row--single">
          <textarea id="contact-message" class="input-bottom min-h-[10rem]" placeholder="Your Message" rows="5" name="message" required><%= formData?.message || '' %></textarea>
        </div>
        <button class="kz-submit" type="submit">Dispatch Inquiry</button>
      </form>
    </div>

    <aside class="kz-contact-side js-reveal" data-reveal>
      <article class="kz-contact-side__card">
        <span>Available focus</span>
        <h3>Live cars from the archive.</h3>
        <p>The inquiry category now pulls real vehicles from the site instead of static placeholder options.</p>
      </article>
      <article class="kz-contact-side__image">
        <img src="/assets/img/coastal.jpeg" alt="Night route">
      </article>
    </aside>
  </section>
</main>

<%- include('../components/footer') %>
<button id="backToTop" type="button" aria-label="Back to top">↑</button>
<script src="/assets/js/app.js"></script>
</body>
</html>
