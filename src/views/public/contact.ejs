<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AutoSalón | Kontakt</title>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Epilogue:wght@300;400;500;600;700&display=swap" />
</head>
<body data-page="contact">
<%- include("../components/header") %>

<main>
  <section class="section">
    <div class="container">
      <h1>Kontakt</h1>
      <p class="section-lead">Napíš nám. Odpovieme čo najskôr.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2">
        <div class="card">
          <h2>Kde nás nájdeš</h2>
          <p>Námestovo</p>
          <p>Tel.: +421 900 000 000</p>
          <p>E-mail: info@autosalon.sk</p>
          <p>Po–Pi: 9:00–17:00</p>
        </div>

        <div class="card">
          <img class="card-img" src="/assets/img/contact-map.svg" alt="Mapa" />
          <p>Budova OC</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Nezáväzný dopyt</h2>
      <form id="contactForm">
        <div class="form-group">
          <label class="form-label" for="contact-name">Meno</label>
          <input class="form-input" id="contact-name" type="text" name="name" required placeholder="Tvoje meno" />
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-email">E-mail</label>
          <input class="form-input" id="contact-email" type="email" name="email" required placeholder="tvoj@email.sk" />
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-car">Zaujíma ma auto</label>
          <select class="form-select" id="contact-car" name="car">
            <option value="">— vyber —</option>
            <option>BMW 3 (2020)</option>
            <option>Audi A4 (2019)</option>
            <option>Mercedes C (2021)</option>
            <option>Iné</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-message">Správa</label>
          <textarea class="form-textarea" id="contact-message" name="message" required placeholder="Napíš, čo potrebuješ..."></textarea>
        </div>

        <button class="btn btn-primary" type="submit">Odoslať</button>
      </form>

      <div id="previewBox" hidden>
        <h3>Preview správy</h3>
        <p id="previewText"></p>
      </div>
    </div>
  </section>
</main>

<%- include("../components/footer") %>
<button id="backToTop" type="button" aria-label="Back to top">↑</button>
<script src="/assets/js/app.js"></script>
</body>
</html>
