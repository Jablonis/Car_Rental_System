<!doctype html>
<html class="dark" lang="en">
<head>
  <%- include('../components/head', { title: 'KARZONE | Luxury Rentals' }) %>
</head>
<body class="bg-surface text-on-surface" data-page="home" id="top">
  <%- include('../components/header') %>

  <main class="kz-home">
    <section class="kz-hero">
      <div class="kz-hero__bleed">
        <img src="/assets/img/hero-garage.jpg" alt="Luxury garage lineup" class="kz-hero__bg" data-parallax="0.02" />
        <div class="kz-hero__overlay"></div>
      </div>

      <div class="kz-shell kz-hero__shell">
        <div class="kz-hero__meta js-reveal" data-reveal>
          <span>NEW YORK, USA</span>
          <span>Exotic car collection<br>By Karzone</span>
          <span>From exotic sports cars to luxury sedans and SUVs, Karzone offers an exceptional selection and personalised service.</span>
        </div>

        <div class="kz-hero__copy js-reveal" data-reveal>
          <span class="kz-hero__edition">001</span>
          <h1>Rent the luxury<br>Own the thrill.</h1>
          <div class="kz-hero__specs">
            <span>Private collection</span>
            <span>Performance grade</span>
            <span>Concierge delivery</span>
          </div>
        </div>
      </div>

      <div class="kz-shell kz-hero__actions js-reveal" data-reveal>
        <a href="/cars">Rent a car <span>→</span></a>
        <a href="/cars">Buy a car <span>→</span></a>
      </div>
    </section>

    <section class="kz-intro kz-shell" id="intro">
      <div class="kz-section-label js-reveal" data-reveal>
        <span></span>
        <p>About us</p>
      </div>
      <div class="kz-intro__grid">
        <div class="kz-intro__headline js-reveal" data-reveal>
          <h2 data-word-reveal>From exotic sports cars to luxury sedans and SUVs, Karzone's Exotic Car Collection offers an exceptional selection and Karzone's trusted, personalised service.</h2>
        </div>
        <div class="kz-intro__aside js-reveal" data-reveal>
          <div class="kz-intro__line"></div>
          <p>We provide the finest luxury cars to hire, from Mercedes-Benz and Porsche to Range Rover, Jaguar and Bentley, carefully matched to your occasion, your route, and your rhythm.</p>
          <div class="kz-counter-grid">
            <div class="kz-counter-card">
              <strong class="js-count" data-count="18">0</strong>
              <span>years of luxury</span>
            </div>
            <div class="kz-counter-card">
              <strong class="js-count" data-count="42">0</strong>
              <span>signature vehicles</span>
            </div>
            <div class="kz-counter-card">
              <strong class="js-count" data-count="100" data-suffix="+">0</strong>
              <span>tailored events</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="kz-atelier kz-shell" id="atelier">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Arrive in style</p>
          </div>
          <p class="kz-section-copy">A darker, cleaner signature section designed to feel more cinematic than a standard featured card.</p>
        </div>
        <div class="kz-section-cta">
          <a href="/cars" class="kz-pill kz-pill--ghost">Rent a car</a>
          <a href="/cars" class="kz-pill">View inventory</a>
        </div>
      </div>

      <div class="kz-atelier__stage js-reveal" data-reveal>
        <div class="kz-atelier__column kz-atelier__column--copy">
          <span class="kz-atelier__eyebrow">Night Atelier</span>
          <h3>Performance, edited with restraint.</h3>
          <p>Instead of a single boxed spotlight, this section behaves more like an editorial feature—image, data, and atmosphere working together in one continuous scene.</p>
          <div class="kz-atelier__stats">
            <div>
              <strong class="js-count" data-count="450">0</strong>
              <span>horsepower</span>
            </div>
            <div>
              <strong class="js-count" data-count="280">0</strong>
              <span>km/h</span>
            </div>
            <div>
              <strong class="js-count" data-count="2024">0</strong>
              <span>atelier series</span>
            </div>
          </div>
          <a href="/cars" class="kz-pill">View details</a>
        </div>

        <div class="kz-atelier__column kz-atelier__column--visual">
          <span class="kz-atelier__title">NOCTURNE</span>
          <div class="kz-atelier__halo"></div>
          <img src="/assets/img/IMG_0286.JPG" alt="Featured Porsche" class="kz-atelier__car" data-parallax="0.015" />
          <div class="kz-atelier__float kz-atelier__float--left">
            <img src="/assets/img/ritual.jpeg" alt="Interior ritual" />
          </div>
          <div class="kz-atelier__float kz-atelier__float--right">
            <img src="/assets/img/coastal.jpeg" alt="Night drive atmosphere" />
          </div>
        </div>
      </div>
    </section>

    <section class="kz-brands kz-shell" id="brands">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Popular exotic & luxury rental makes</p>
          </div>
          <p class="kz-section-copy">A logo-ready strip you can later replace with official SVG marks without changing the layout.</p>
        </div>
        <p class="kz-brands__copy">This band is intentionally more fluid and less static than the old card set—closer to a premium automotive partner wall.</p>
      </div>

      <div class="kz-brand-marquee js-reveal" data-reveal>
        <div class="kz-brand-track">
          <% ['Bugatti', 'Ferrari', 'Lamborghini', 'Jaguar', 'Bentley', 'Porsche', 'Aston Martin', 'Range Rover'].forEach(function(brand) { %>
            <article class="kz-brand-pill">
              <span class="kz-brand-mark"><%= brand.charAt(0) %></span>
              <span class="kz-brand-name"><%= brand %></span>
            </article>
          <% }) %>
        </div>
        <div class="kz-brand-track kz-brand-track--clone" aria-hidden="true">
          <% ['Bugatti', 'Ferrari', 'Lamborghini', 'Jaguar', 'Bentley', 'Porsche', 'Aston Martin', 'Range Rover'].forEach(function(brand) { %>
            <article class="kz-brand-pill">
              <span class="kz-brand-mark"><%= brand.charAt(0) %></span>
              <span class="kz-brand-name"><%= brand %></span>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="kz-service kz-shell" id="service">
      <div class="kz-service__grid">
        <div class="kz-service__visual js-reveal" data-reveal>
          <img src="/assets/img/coastal.jpeg" alt="Superior customer service" data-parallax="0.03" />
          <div class="kz-service__floating-card">
            <span>Concierge</span>
            <strong>24/7 Route planning</strong>
            <p>Airport handoff, event delivery, white-glove return.</p>
          </div>
        </div>
        <div class="kz-service__content js-reveal" data-reveal>
          <span class="kz-service__eyebrow">Superior customer service</span>
          <h2>More than a rental.<br>A fully staged arrival.</h2>
          <p>Experience exotic car rentals from a team that treats logistics as part of the luxury. We handle route planning, timed delivery, on-location handoff, and discreet collection with the same care as the vehicle itself.</p>
          <div class="kz-service__cards">
            <article>
              <strong>01</strong>
              <span>Private concierge line</span>
            </article>
            <article>
              <strong>02</strong>
              <span>Flexible collection windows</span>
            </article>
            <article>
              <strong>03</strong>
              <span>Event-ready vehicle prep</span>
            </article>
          </div>
          <a href="/contact" class="kz-pill">View details</a>
        </div>
      </div>
    </section>

    <section class="kz-journal kz-shell" id="journal-preview">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Journal preparation</p>
          </div>
          <p class="kz-section-copy">A future-ready section for blog/editorial stories, already aligned with the homepage style.</p>
        </div>
      </div>
      <div class="kz-journal__grid">
        <article class="kz-story-card js-reveal" data-reveal>
          <img src="/assets/img/ritual.jpeg" alt="Midnight ritual">
          <div>
            <span>Story 001</span>
            <h3>Midnight rituals in the city garage.</h3>
            <p>Prepared as a future blog card component for long-form editorial pieces.</p>
          </div>
        </article>
        <article class="kz-story-card js-reveal" data-reveal>
          <img src="/assets/img/coastal.jpeg" alt="Coastal route">
          <div>
            <span>Story 002</span>
            <h3>Coastal runs and early light.</h3>
            <p>Reusable for journal previews, launch posts, and curation notes.</p>
          </div>
        </article>
        <article class="kz-story-card js-reveal" data-reveal>
          <img src="/assets/img/cars/car-1.jpg" alt="Performance detail">
          <div>
            <span>Story 003</span>
            <h3>Mechanical notes for collectors.</h3>
            <p>A flexible system you can extend into a full blog page later.</p>
          </div>
        </article>
      </div>
    </section>
  </main>

  <%- include('../components/footer') %>
  <button id="backToTop" type="button" aria-label="Back to top">↑</button>
  <script src="/assets/js/app.js"></script>
</body>
</html>
