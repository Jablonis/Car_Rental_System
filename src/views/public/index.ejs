<!doctype html>
<html class="dark" lang="en">
<head>
  <%- include('../components/head', { title: 'VELOCITY | Luxury Rentals' }) %>
</head>
<body class="bg-surface text-on-surface" data-page="home" id="top">
  <%- include('../components/header') %>

  <main class="kz-home">
    <section class="kz-hero">
      <div class="kz-hero__bleed">
        <img src="/assets/img/hero-garage.webp" alt="Luxury garage lineup" class="kz-hero__bg" data-parallax="0.02" />
        <div class="kz-hero__overlay"></div>
      </div>

      <div class="kz-shell kz-hero__shell">
        <div class="kz-hero__meta js-reveal" data-reveal>
          <span>NEW YORK, USA</span>
          <span>Exotic car collection<br>By Velocity</span>
          <span>From exotic sports cars to luxury sedans and SUVs, Velocity offers an exceptional selection and personalised service.</span>
        </div>

        <div class="kz-hero__copy js-reveal" data-reveal>
          <span class="kz-hero__edition">001</span>
          <h1>Rent the luxury<br>Own the thrill.</h1>
          <div class="kz-hero__specs">
            <span>Private collection</span>
            <span>Performance grade</span>
            <span>Concierge delivery</span>
          </div>
        </div>
      </div>

      <div class="kz-shell kz-hero__actions js-reveal" data-reveal>
        <a href="/cars">Rent a car <span>→</span></a>
        <a href="/cars">Buy a car <span>→</span></a>
      </div>
    </section>

    <section class="kz-intro kz-shell" id="intro">
      <div class="kz-section-label js-reveal" data-reveal>
        <span></span>
        <p>About us</p>
      </div>
      <div class="kz-intro__grid">
        <div class="kz-intro__headline js-reveal" data-reveal>
          <h2 data-word-reveal>From exotic sports cars to luxury sedans and SUVs, Velocity's Exotic Car Collection offers an exceptional selection and Velocity's trusted, personalised service.</h2>
        </div>
        <div class="kz-intro__aside js-reveal" data-reveal>
          <div class="kz-intro__line"></div>
          <p>We provide the finest luxury cars to hire, from Mercedes-Benz and Porsche to Range Rover, Jaguar and Bentley, carefully matched to your occasion, your route, and your rhythm.</p>
          <div class="kz-counter-grid">
            <div class="kz-counter-card">
              <strong class="js-count" data-count="18">0</strong>
              <span>years of luxury</span>
            </div>
            <div class="kz-counter-card">
              <strong class="js-count" data-count="42">0</strong>
              <span>signature vehicles</span>
            </div>
            <div class="kz-counter-card">
              <strong class="js-count" data-count="100" data-suffix="+">0</strong>
              <span>tailored events</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="kz-arrivals kz-shell" id="latest-arrivals">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Latest arrivals</p>
          </div>
          <p class="kz-section-copy">A slow-moving gallery of the newest cars added by Velocity members—less static, more alive.</p>
        </div>
        <a href="/cars" class="kz-pill">Browse inventory</a>
      </div>

      <div class="kz-arrivals__marquee js-reveal" data-reveal>
        <% const showcaseCars = (latestCars && latestCars.length ? latestCars : []).slice(0, 8); %>
        <% const showcaseLoop = showcaseCars.length ? showcaseCars.concat(showcaseCars) : []; %>
        <% if (showcaseLoop.length) { %>
          <div class="kz-arrivals__track">
            <% showcaseLoop.forEach((car, index) => { %>
              <article class="kz-arrival-card" aria-hidden="<%= index >= showcaseCars.length ? 'true' : 'false' %>">
                <a href="/cars/<%= car.car_id %>" class="kz-arrival-card__media">
                  <img src="<%= car.image %>" alt="<%= car.title %>">
                </a>
                <div class="kz-arrival-card__body">
                  <div>
                    <span class="kz-arrival-card__eyebrow">Latest by members</span>
                    <h3><%= car.title %></h3>
                    <p><%= car.brand %> <%= car.model %> · <%= car.year %> · <%= Number(car.price).toLocaleString('en-US') %> €<% if (car.owner_name) { %> · added by <%= car.owner_name %><% } %></p>
                  </div>
                  <div class="kz-arrival-card__meta">
                    <span><%= car.mileage %> km</span>
                    <span><%= car.fuel %></span>
                    <span><%= car.transmission %></span>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="kz-arrivals__empty">
            <p>No latest cars yet. Add the first listing and it will appear here automatically.</p>
          </div>
        <% } %>
      </div>
    </section>

    <section class="kz-brands kz-shell" id="brands">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Popular exotic & luxury rental makes</p>
          </div>
          <p class="kz-section-copy">A logo-ready strip you can later replace with official SVG marks without changing the layout.</p>
        </div>
        <p class="kz-brands__copy">This band is intentionally more fluid and less static than the old card set—closer to a premium automotive partner wall.</p>
      </div>

      <% const featuredBrands = ['Bugatti', 'Ferrari', 'Lamborghini', 'Jaguar', 'Bentley', 'Porsche', 'Aston Martin', 'Range Rover']; %>
      <div class="kz-brand-marquee js-reveal" data-reveal>
        <div class="kz-brand-track">
          <% featuredBrands.concat(featuredBrands).forEach(function(brand, index) { %>
            <article class="kz-brand-pill" aria-hidden="<%= index >= featuredBrands.length ? 'true' : 'false' %>">
              <span class="kz-brand-mark"><%= brand.charAt(0) %></span>
              <span class="kz-brand-name"><%= brand %></span>
            </article>
          <% }) %>
        </div>
      </div>
    </section>

    <section class="kz-service kz-shell" id="service">
      <div class="kz-service__grid">
        <div class="kz-service__visual js-reveal" data-reveal>
          <img src="/assets/img/coastal.webp" alt="Superior customer service" data-parallax="0.03" />
          <div class="kz-service__floating-card">
            <span>Concierge</span>
            <strong>24/7 Route planning</strong>
            <p>Airport handoff, event delivery, white-glove return.</p>
          </div>
        </div>
        <div class="kz-service__content js-reveal" data-reveal>
          <span class="kz-service__eyebrow">Superior customer service</span>
          <h2>More than a rental.<br>A fully staged arrival.</h2>
          <p>Experience exotic car rentals from a team that treats logistics as part of the luxury. We handle route planning, timed delivery, on-location handoff, and discreet collection with the same care as the vehicle itself.</p>
          <div class="kz-service__cards">
            <article>
              <strong>01</strong>
              <span>Private concierge line</span>
            </article>
            <article>
              <strong>02</strong>
              <span>Flexible collection windows</span>
            </article>
            <article>
              <strong>03</strong>
              <span>Event-ready vehicle prep</span>
            </article>
          </div>
          <a href="/contact" class="kz-pill">View details</a>
        </div>
      </div>
    </section>

    <section class="kz-journal kz-shell" id="journal-preview">
      <div class="kz-section-head js-reveal" data-reveal>
        <div>
          <div class="kz-section-label kz-section-label--inline">
            <span></span>
            <p>Journal</p>
          </div>
          <p class="kz-section-copy">Live editorial entries written by the admin. Publish once and the homepage updates automatically.</p>
        </div>
        <a href="/journal" class="kz-pill kz-pill--ghost">Open journal</a>
      </div>
      <div class="kz-journal__grid">
        <% if (!latestBlogs || !latestBlogs.length) { %>
          <article class="kz-story-card js-reveal" data-reveal>
            <img src="/assets/img/ritual.webp" alt="Journal placeholder">
            <div>
              <span>Awaiting first post</span>
              <h3>The journal is live—now publish the first story.</h3>
              <p>Open the admin console and create the first blog entry. It will appear here immediately after publishing.</p>
            </div>
          </article>
        <% } %>
        <% (latestBlogs || []).forEach((post) => { %>
          <article class="kz-story-card js-reveal" data-reveal>
            <a href="/journal/<%= post.slug %>"><img src="<%= post.image %>" alt="<%= post.title %>"></a>
            <div>
              <span><%= new Date(post.created_at || Date.now()).toLocaleDateString('en-GB') %></span>
              <h3><a href="/journal/<%= post.slug %>"><%= post.title %></a></h3>
              <p><%= post.excerpt %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('../components/footer') %>
  <button id="backToTop" type="button" aria-label="Back to top">↑</button>
  <script src="/assets/js/app.js"></script>
</body>
</html>
