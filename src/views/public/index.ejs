<%- include('../components/header') %>

<main class="nocturne-shell">
  <header class="relative h-screen w-full flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img class="w-full h-full object-cover grayscale opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBbrpR290ZEt5WOlZJkdOfLGOm4Bpo2T5HuWtrm0kBJjhRSTcE4HmncFkLsar5f9O7A8sDvQSuhNeIPfl5gUUrKPpP7Nxmz6B1Oc2TFJ_QBDcnS54Te6X-3paRcOQekim5XEUVg8QDTXly3niMSFF0uQ4Nwpr63SePWgQKSolpa04K7c9a17Az6vKmJAKLyFBf5aleuMuRR2i6ZajrUiWHHGM6iLAcUp_r9KUofhcnwUOl1tEjM06XQI26Byl98EZU-yqLDYN0sL6Wq" alt="Cinematic Porsche" />
      <div class="absolute inset-0 bg-gradient-to-b from-surface/20 via-surface/60 to-surface"></div>
    </div>
    <div class="relative z-10 w-full px-6 md:px-12 max-w-7xl pt-20">
      <div class="flex flex-col gap-4">
        <span class="tracking-[0.4em] uppercase text-primary font-semibold text-[10px] md:text-xs">Volume IV // The Curated Motion</span>
        <h1 class="text-6xl md:text-9xl font-headline font-bold tracking-tighter leading-none max-w-4xl text-on-surface">
          Mechanical <br>
          <span class="italic text-primary/80">Elegance.</span>
        </h1>
        <div class="mt-8 flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
          <div class="flex items-center gap-8 md:gap-12">
            <div class="flex flex-col">
              <span class="font-headline text-3xl font-bold">964</span>
              <span class="text-[10px] uppercase tracking-widest text-on-surface-variant">Generation</span>
            </div>
            <div class="w-px h-12 bg-outline-variant/30 hidden md:block"></div>
            <div class="flex flex-col">
              <span class="font-headline text-3xl font-bold">1992</span>
              <span class="text-[10px] uppercase tracking-widest text-on-surface-variant">Epoch</span>
            </div>
          </div>
          <p class="max-w-xs text-sm leading-relaxed text-on-surface-variant">
            A definitive exploration of the air-cooled era. Curated Motion traverses the boundary between engineering and sculpture.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/cars" class="bg-gradient-to-br from-primary to-on-primary-container text-on-primary-fixed px-8 py-3 rounded-full font-bold text-xs tracking-[0.24em] uppercase hover:scale-105 transition-transform">View Inventory</a>
          <a href="/about" class="border border-outline-variant/20 text-on-surface px-8 py-3 rounded-full font-bold text-xs tracking-[0.24em] uppercase hover:border-primary/40 hover:text-primary transition-colors">Our Ethos</a>
        </div>
