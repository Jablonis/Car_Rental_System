              <div><span class="text-[10px] uppercase tracking-widest text-on-surface-variant block mb-1">Peak Power</span><span class="font-headline text-lg md:text-xl">620 BHP</span></div>
              <div><span class="text-[10px] uppercase tracking-widest text-on-surface-variant block mb-1">Weight</span><span class="font-headline text-lg md:text-xl">1,340 KG</span></div>
