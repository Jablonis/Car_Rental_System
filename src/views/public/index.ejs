<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AutoSalón | Domov</title>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&family=Epilogue:wght@300;400;500;600;700&display=swap" />
</head>
<body data-page="home">
<%- include("../components/header") %>

<main>
  <section class="hero">
    <div class="container">
      <span class="badge">Predaj & dovoz áut</span>
      <h1 class="hero-title">Auto, ktoré sadne na prvé otočenie kľúčom.</h1>
      <p class="section-lead">Jednoduchý výber, férová komunikácia, jasný stav vozidla. Pozri si ponuku a vyberieme spolu to správne.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/cars">Pozrieť ponuku áut</a>
        <a class="btn" href="/contact">Nezáväzný dopyt</a>
      </div>
      <div class="kpis">
        <div class="kpi"><strong>50+ áut</strong><span>v ponuke</span></div>
        <div class="kpi"><strong>Overený pôvod</strong><span>jasná história</span></div>
        <div class="kpi"><strong>Rýchly kontakt</strong><span>odpoveď do 24h</span></div>
      </div>
    </div>
  </section>

  <section class="section small">
    <div class="container">
      <h2>Prečo práve my</h2>
      <p class="section-lead">Nehráme sa na luxusné reči. Chceme, aby si odchádzal spokojný a vedel, čo kupuješ.</p>
      <div class="grid-3" style="margin-top: 18px;">
        <div class="card">
          <h3>Jasný stav</h3>
          <p>Každé auto má základný popis aj detaily. Nič neskrývame a komunikujeme priamo.</p>
        </div>
        <div class="card">
          <h3>Jednoduchý proces</h3>
          <p>Výber → kontakt → obhliadka → papiere. Bez chaosu a bez zbytočného tlaku.</p>
        </div>
        <div class="card">
          <h3>Ľudský prístup</h3>
          <p>Komunikujeme normálne. Keď niečo nevieme, povieme to a nájdeme riešenie.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Ako to funguje</h2>
          <p class="section-lead">Tri kroky, ktoré pochopíš na prvý pohľad.</p>
          <div class="steps">
            <div class="step">
              <div class="step-num">1</div>
              <div>
                <h3>Vyber si auto</h3>
                <p>Pozri ponuku, prefiltruj podľa názvu a otvor si detaily, ktoré ťa zaujímajú.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <div>
                <h3>Napíš alebo zavolaj</h3>
                <p>Dohodneme obhliadku, rezerváciu alebo odpovieme na konkrétne otázky.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <div>
                <h3>Hotovo</h3>
                <p>Pomôžeme s papiermi, prepisom a odporučíme ďalší postup aj servis.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <img class="card-img" src="/assets/img/gallery/g-1.jpg" alt="Ukážka showroomu" />
          <h3>Nocturne drive výber</h3>
          <p>Autá, ktoré dobre vyzerajú, jazdia bez kompromisov a majú jasný príbeh.</p>
          <a class="btn btn-small" href="/about">Viac o nás</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Top výber</h2>
      <p class="section-lead">Krátka ochutnávka. Celú ponuku nájdeš na stránke Ponuka áut.</p>
      <div class="grid-3" style="margin-top: 18px;">
        <article class="car-card">
          <img class="car-card-img" src="/assets/img/cars/car-1.jpg" alt="BMW 3" />
          <div class="car-card-body">
            <h3 class="car-card-title">BMW 3 • 2020</h3>
            <div class="car-meta">
              <span class="car-meta-item">Automat</span>
              <span class="car-meta-item">140 kW</span>
              <span class="car-meta-item">85 000 km</span>
            </div>
            <div class="car-actions">
              <a class="btn btn-small btn-primary" href="/cars">Pozrieť ponuku</a>
            </div>
          </div>
        </article>

        <article class="car-card">
          <img class="car-card-img" src="/assets/img/cars/car-2.jpg" alt="Audi A4" />
          <div class="car-card-body">
            <h3 class="car-card-title">Audi A4 • 2019</h3>
            <div class="car-meta">
              <span class="car-meta-item">Quattro</span>
              <span class="car-meta-item">150 kW</span>
              <span class="car-meta-item">92 000 km</span>
            </div>
            <div class="car-actions">
              <a class="btn btn-small btn-primary" href="/cars">Pozrieť ponuku</a>
            </div>
          </div>
        </article>

        <article class="car-card">
          <img class="car-card-img" src="/assets/img/cars/car-3.svg" alt="Mercedes C" />
          <div class="car-card-body">
            <h3 class="car-card-title">Mercedes C • 2021</h3>
            <div class="car-meta">
              <span class="car-meta-item">AMG Line</span>
              <span class="car-meta-item">145 kW</span>
              <span class="car-meta-item">55 000 km</span>
            </div>
            <div class="car-actions">
              <a class="btn btn-small btn-primary" href="/cars">Pozrieť ponuku</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>FAQ</h2>
      <p class="section-lead">Najčastejšie otázky, ktoré rieši väčšina ľudí pri kúpe auta.</p>
      <div class="faq">
        <button class="faq-item" type="button">
          <span>Máte možnosť rezervácie?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-content">
          Rezervácia je možná po dohode. Napíš nám do kontaktu a dohodneme si podmienky.
        </div>

        <button class="faq-item" type="button">
          <span>Dá sa auto preveriť v servise?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-content">
          Áno. Odporúčame obhliadku aj v servise – je to najlepšie pre obe strany.
        </div>

        <button class="faq-item" type="button">
          <span>Pomôžete s prepisom a papiermi?</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-content">
          Pomôžeme s papiermi, základným procesom aj ďalším postupom po kúpe.
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("../components/footer") %>
<button id="backToTop" type="button" aria-label="Back to top">↑</button>
<script src="/assets/js/app.js"></script>
</body>
</html>
