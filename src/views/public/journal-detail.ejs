<!doctype html>
<html class="dark" lang="en">
<head>
  <%- include('../components/head', { title: `Velocity | ${post.title}` }) %>
</head>
<body class="bg-surface text-on-surface" data-page="journal" id="top">
<%- include('../components/header') %>

<main class="kz-subpage kz-subpage--journal-detail kz-shell">
  <article class="kz-article-hero">
    <div class="kz-article-hero__media">
      <img src="<%= post.image %>" alt="<%= post.title %>">
    </div>
    <div class="kz-article-hero__copy">
      <span class="kz-page-hero__eyebrow">Journal entry</span>
      <h1><%= post.title %></h1>
      <p><%= post.excerpt %></p>
      <div class="kz-article-hero__meta"><%= new Date(post.created_at || Date.now()).toLocaleDateString('en-GB') %></div>
    </div>
  </article>

  <section class="kz-article-body">
    <% String(post.content || '').split(/\n\n+/).forEach((paragraph) => { %>
      <p><%= paragraph %></p>
    <% }) %>
  </section>

  <section class="kz-comments" id="comments">
    <div class="kz-section-head">
      <div>
        <div class="kz-section-label kz-section-label--inline"><span></span><p>Reader comments</p></div>
      </div>
      <span class="kz-pill kz-pill--ghost"><%= comments.length %> approved</span>
    </div>

    <% if (commentNotice) { %>
      <div class="alert-luxe mb-6"><%= commentNotice %></div>
    <% } %>

    <div class="kz-comments__grid">
      <div class="kz-comments__list">
        <% if (!comments.length) { %>
          <article class="kz-comment-card">
            <p class="text-on-surface-variant">No approved comments yet. Be the first to respond once moderation opens this discussion.</p>
          </article>
        <% } %>
        <% comments.forEach((comment) => { %>
          <article class="kz-comment-card">
            <div class="kz-comment-card__head">
              <div class="kz-comment-card__author">
                <% if (comment.user_avatar) { %><img src="<%= comment.user_avatar %>" alt="<%= comment.user_name %>" class="kz-comment-card__avatar"> <% } %>
                <div>
                  <strong><%= comment.user_name %></strong>
                  <span><%= new Date(comment.created_at || Date.now()).toLocaleDateString('en-GB') %></span>
                </div>
              </div>
            </div>
            <p><%= comment.content %></p>
          </article>
        <% }) %>
      </div>

      <aside class="kz-comment-form-wrap">
        <h2>Leave a comment</h2>
        <p class="text-on-surface-variant mb-5">Comments are submitted for moderation before they appear publicly.</p>
        <% if (locals.isAuthenticated) { %>
          <% if (commentErrors && commentErrors.length) { %>
            <div class="alert-luxe form-error-list mb-6">
              <% commentErrors.forEach((error) => { %><div><%= error.message %></div><% }) %>
            </div>
          <% } %>
          <form method="POST" action="/journal/<%= post.slug %>/comments" class="space-y-5">
            <div>
              <label class="block text-[10px] uppercase tracking-[0.28em] text-outline mb-3">Your comment</label>
              <textarea class="form-textarea-luxe min-h-[12rem]" name="content" placeholder="Share your perspective respectfully..."><%= commentFormData.content || '' %></textarea>
            </div>
            <button type="submit" class="px-8 py-4 rounded-full bg-gradient-to-r from-primary to-primary-container text-on-primary-fixed font-bold text-[10px] uppercase tracking-[0.24em]">Submit for approval</button>
          </form>
        <% } else { %>
          <div class="kz-comment-login-note">
            <p class="text-on-surface-variant mb-5">You need an account to comment on journal entries.</p>
            <a href="/login" class="kz-pill">Log in to comment</a>
          </div>
        <% } %>
      </aside>
    </div>
  </section>

  <% if (relatedPosts.length) { %>
    <section class="kz-journal kz-related-posts">
      <div class="kz-section-head">
        <div>
          <div class="kz-section-label kz-section-label--inline"><span></span><p>Related reading</p></div>
        </div>
      </div>
      <div class="kz-journal__grid">
        <% relatedPosts.forEach((entry) => { %>
          <article class="kz-story-card">
            <a href="/journal/<%= entry.slug %>"><img src="<%= entry.image %>" alt="<%= entry.title %>"></a>
            <div>
              <span><%= new Date(entry.created_at || Date.now()).toLocaleDateString('en-GB') %></span>
              <h3><a href="/journal/<%= entry.slug %>"><%= entry.title %></a></h3>
              <p><%= entry.excerpt %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</main>

<%- include('../components/footer') %>
<button id="backToTop" type="button" aria-label="Back to top">↑</button>
<script src="/assets/js/app.js"></script>
</body>
</html>
